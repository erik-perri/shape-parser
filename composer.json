{
    "name": "sourcetoad/shape-parser",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Sourcetoad\\ShapeParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sourcetoad\\ShapeParser\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "check-code": [
            "@phpstan",
            "@lint",
            "@test"
        ],
        "lint": "@php vendor/bin/pint --test",
        "lint:fix": "@php vendor/bin/pint",
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test": "@php vendor/bin/phpunit"
    }
}
